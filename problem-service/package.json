{
  "name": "problem-service",
  "version": "0.1.0",
  "private": true,
  "description": "Internal problem ingestion service for Polygon and Codeforces.",
  "main": "src/app.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/app.ts",
    "start": "bun src/app.ts",
    "docker:up": "docker compose -f ../docker-compose.yml up -d",
    "docker:down": "docker compose -f ../docker-compose.yml down -v",
    "docker:logs": "docker compose -f ../docker-compose.yml logs -f"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "archiver": "^8.0.0",
    "axios": "^1.18.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fast-xml-parser": "^5.9.3",
    "pg": "^8.12.0",
    "unzipper": "^0.12.5"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.6.6",
    "@types/unzipper": "^0.10.11",
    "typescript": "^5.2.2"
  }
}
