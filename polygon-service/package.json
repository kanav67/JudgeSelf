{
  "name": "polygon-service",
  "version": "0.1.0",
  "private": true,
  "description": "Internal problem ingestion service for Polygon and Codeforces.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "docker:up": "docker compose -f ../docker-compose.yml up -d",
    "docker:down": "docker compose -f ../docker-compose.yml down -v",
    "docker:logs": "docker compose -f ../docker-compose.yml logs -f"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@types/express": "^5.0.6",
    "archiver": "^8.0.0",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.10.0",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/redis": "^4.0.11",
    "@types/unzipper": "^0.10.11",
    "typescript": "^5.9.3",
    "@types/bun": "latest"
  }
}
