POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/postgres

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_SUBMISSIONS=submissions
RABBITMQ_QUEUE_VERDICTS=verdicts

REDIS_ADDR=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STATUS_CHANNEL=status_updates

JWT_ACCESS_TOKEN_SECRET= # change it
JWT_REFRESH_TOKEN_SECRET= # change it

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=problem-service
S3_SECRET_ACCESS_KEY=problem-service-secret
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET=problem-service-artifacts

POLYGON_USERNAME= # change it
POLYGON_PASSWORD= # change it

NODE_ENV=development # change it to production in production environment